<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.frontleaves.scheduling.mappers.TeacherMapper">
    <!-- 结果映射 -->
    <resultMap id="userAndTeacherResultMap" type="com.frontleaves.scheduling.models.entity.multiple.UserAndTeacherDO">
        <!-- User 映射 -->
        <association property="user" javaType="com.frontleaves.scheduling.models.entity.UserDO">
            <id property="userUuid" column="userUuid"/>
            <result property="name" column="user_name"/>
            <result property="password" column="password"/>
            <result property="email" column="user_email"/>
            <result property="phone" column="user_phone"/>
            <result property="status" column="status"/>
            <result property="ban" column="ban"/>
            <result property="roleUuid" column="roleUuid"/>
            <result property="permission" column="permission"/>
            <result property="createdAt" column="user_createdAt"/>
            <result property="updatedAt" column="user_updatedAt"/>
        </association>

        <!-- Teacher 映射 -->
        <association property="teacher" javaType="com.frontleaves.scheduling.models.entity.TeacherDO">
            <id property="teacherUuid" column="teacherUuid"/>
            <result property="unitUuid" column="unitUuid"/>
            <result property="userUuid" column="teacher_userUuid"/>
            <result property="id" column="id"/>
            <result property="name" column="teacher_name"/>
            <result property="englishName" column="englishName"/>
            <result property="ethnic" column="ethnic"/>
            <result property="sex" column="sex"/>
            <result property="phone" column="teacher_phone"/>
            <result property="email" column="teacher_email"/>
            <result property="jobTitle" column="jobTitle"/>
            <result property="desc" column="desc"/>
            <result property="createdAt" column="teacher_createdAt"/>
            <result property="updatedAt" column="teacher_updatedAt"/>
        </association>
    </resultMap>

    <!-- 查询语句 -->
    <select id="getTeacherAndUserQueryDesc" resultMap="userAndTeacherResultMap">
        SELECT
            <!-- Teacher 表字段 -->
            cs_teacher.teacher_uuid AS teacherUuid,
            cs_teacher.unit_uuid AS unitUuid,
            cs_teacher.user_uuid AS teacher_userUuid,
            cs_teacher.id,
            cs_teacher.name AS teacher_name,
            cs_teacher.english_name AS englishName,
            cs_teacher.ethnic,
            cs_teacher.sex,
            cs_teacher.phone AS teacher_phone,
            cs_teacher.email AS teacher_email,
            cs_teacher.job_title AS jobTitle,
            cs_teacher.`desc`,
            cs_teacher.created_at AS teacher_createdAt,
            cs_teacher.updated_at AS teacher_updatedAt,

            <!-- User 表字段 -->
            cs_user.user_uuid AS userUuid,
            cs_user.name AS user_name,
            cs_user.password,
            cs_user.email AS user_email,
            cs_user.phone AS user_phone,
            cs_user.status,
            cs_user.ban,
            cs_user.role_uuid AS roleUuid,
            cs_user.permission,
            cs_user.created_at AS user_createdAt,
            cs_user.updated_at AS user_updatedAt
        FROM cs_teacher
        LEFT JOIN cs_user ON cs_teacher.user_uuid = cs_user.user_uuid
        WHERE (#{departmentUuid} IS NULL OR cs_teacher.unit_uuid = #{departmentUuid})
        AND (#{status} IS NULL OR #{status} = '' OR cs_user.status = #{status})
        AND (#{name} IS NULL OR cs_teacher.name LIKE CONCAT('%', #{name}, '%'))
        ORDER BY cs_teacher.created_at DESC
        LIMIT #{page}, #{size}
    </select>
</mapper>
